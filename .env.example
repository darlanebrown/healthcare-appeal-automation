VITE_API_BASE_URL=https://api.example.com

# Epic on FHIR — placeholders until App Orchard registration exists
VITE_EPIC_CLIENT_ID=your-epic-client-id
VITE_EPIC_REDIRECT_URI=https://app.example.com/epic/callback
# EHR launch (production/embedded): omit VITE_EPIC_FHIR_BASE_URL and scope with "launch"; iss/launch come from the EHR launch URL
# Standalone launch (e.g. Epic's public sandbox): set VITE_EPIC_FHIR_BASE_URL and scope with "launch/patient"
VITE_EPIC_SCOPES=launch openid fhirUser patient/*.read
# Example shape only — get the current sandbox FHIR base URL from your fhir.epic.com app registration
VITE_EPIC_FHIR_BASE_URL=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
