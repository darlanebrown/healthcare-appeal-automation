VITE_API_BASE_URL=https://api.example.com

# SMART on FHIR — vendor-neutral client, currently pointed at Oracle Health's
# public Millennium sandbox (no registration or OAuth needed for reads there).
VITE_FHIR_BASE_URL=https://fhir-open.cerner.com/r4/ec2458f2-1e24-41c8-b71b-0e701af7583d
# A known test patient on that open sandbox, used as the default in the UI's patient ID field.
VITE_FHIR_DEFAULT_PATIENT_ID=12742400

# The following are only needed for the OAuth SMART launch flow (production
# EHR launch, or an authenticated sandbox/tenant) — not required for the open
# sandbox above, which needs no client registration.
VITE_FHIR_CLIENT_ID=your-client-id
VITE_FHIR_REDIRECT_URI=https://app.example.com/fhir/callback
# EHR launch (production/embedded): omit VITE_FHIR_BASE_URL and scope with "launch"; iss/launch come from the EHR launch URL
# Standalone launch (e.g. a vendor's public sandbox): set VITE_FHIR_BASE_URL and scope with "launch/patient"
VITE_FHIR_SCOPES=launch openid fhirUser patient/*.read
